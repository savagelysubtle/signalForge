# SignalForge Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — your keys stay local.

# ── LLM API Keys ──────────────────────────────────────────
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
CHARTIMG_API_KEY=

# ── Cloud Infrastructure ──────────────────────────────────
# Set ENVIRONMENT=production for cloud deploys, development for local
ENVIRONMENT=development

# Database (leave blank for local SQLite fallback)
DATABASE_URL=

# Supabase (auth + chart image storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173
